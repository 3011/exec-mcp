{
  "name": "exec-mcp",
  "version": "0.3.0",
  "description": "Bounded SSH remote execution and file-transfer gateway for trusted MCP clients",
  "private": true,
  "type": "module",
  "main": "dist/src/server.js",
  "scripts": {
    "start": "node dist/src/server.js",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "npm run build && node --test test/*.test.js",
    "test:compiled": "node --test test/*.test.js",
    "test:memory": "npm run build && bash scripts/memory-smoke.sh",
    "validate": "bash scripts/validate.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/3011/exec-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/3011/exec-mcp/issues"
  },
  "homepage": "https://github.com/3011/exec-mcp#readme",
  "keywords": [
    "mcp",
    "ssh",
    "remote-execution",
    "gateway",
    "model-context-protocol"
  ]
}
